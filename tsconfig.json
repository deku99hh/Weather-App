{
  "compilerOptions": {
    "target": "ES6",            // المتصفحات الحديثة بتفهم ES6
    "module": "ESNext",         // عشان يستخدم نظام الـ Import/Export بتاع المتصفح
    "rootDir": "./src",         // مكان ملفات الـ ts
    "outDir": "./dist",         // مكان الملفات الناتجة
    "lib": ["DOM", "ESNext"],   // عشان يفهم الـ document والـ window
    "moduleResolution": "node",
    "esModuleInterop": true
  }
}